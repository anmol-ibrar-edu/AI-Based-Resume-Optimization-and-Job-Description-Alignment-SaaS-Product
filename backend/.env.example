# Example .env file for AI Resume Optimizer
# Copy this to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://postgres:password123@db:5432/resume_optimizer

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# APPLICATION SETTINGS
# ============================================
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,docx

# ============================================
# AI/ML API KEYS (OPTIONAL - for enhanced parsing)
# ============================================
# Leave empty to use local spaCy-based parsing
# Add keys to enable AI-enhanced parsing (better accuracy)

# OpenAI API Key (for GPT-3.5/GPT-4 based parsing)
OPENAI_API_KEY=

# Google API Key (for Gemini-based parsing)
GOOGLE_API_KEY=

# Which AI service to prefer (openai|gemini|local)
AI_SERVICE_PREFERRED=local

# ============================================
# FEATURE FLAGS
# ============================================
USE_AI_PARSING=False
ENABLE_OCR=False

# ============================================
# EMAIL / SMTP (Hostinger)
# ============================================
MAIL_SERVER=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=ResumeAI
MAIL_USE_TLS=True
MAIL_USE_STARTTLS=False

# ============================================
# FRONTEND URL (for email links)
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# ADMIN USERS CONFIGURATION
# ============================================
# Comma separated list of emails that will be promoted to admin on first run
ADMIN_EMAILS=admin@example.com
ADMIN_DEFAULT_PASSWORD=Admin123!

# ============================================
# NOTES
# ============================================
# 1. Never commit .env file to version control
# 2. Generate a strong SECRET_KEY using: openssl rand -hex 32
# 3. AI API keys are optional - system works without them
# 4. For production, set DEBUG=False
# 5. Update ALLOWED_ORIGINS for your production domains
# 6. Update MAIL_* settings with your Hostinger email credentials
# 7. Update FRONTEND_URL to your production domain
